{
  "AccessLog": {
    "MaxBodySize": 2048
  },
  "AllowedHosts": "*",
  "Consul": {
    "Enable": true,
    "Name": "WechatAPI",
    "Host": "http://127.0.0.1:10002",
    "Tags": [
      "WechatAPI"
    ],
    "HealthInterval": 60,
    "HealthHost": "http://127.0.0.1:5000",
    "ServiceHost": "http://127.0.0.1:5000"
  },
  "Exception": {
    "ShowException": true,
    "ErrorMessage": "服务器出错了！请联系管理员。"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "MateralLogger": {
      "Application": "${ApplicationName}",
      "Scopes": {
        "MergeBlockAccessLog": "None"
      },
      "Targets": [
        {
          "Name": "ConsoleLog",
          "Type": "Console",
          "Format": "${DateTime}|${Application}|${Level}|${Scope}|${CategoryName}\r\n${Message}\r\n${Exception}"
        },
        {
          "Name": "AccessLog",
          "Type": "Console",
          "Format": "${DateTime}|${Application}|${Level}|${Scope}|${CategoryName}\r\n${Message}"
        }
      ],
      "Rules": [
        {
          "Name": "配置文件规则",
          "Targets": [
            "ConsoleLog"
          ]
        },
        {
          "Name": "访问日志规则",
          "Targets": [
            "AccessLog"
          ],
          "Scopes": {
            "Default": "None",
            "MergeBlockAccessLog": "Trace"
          }
        }
      ]
    }
  },
  "MergeBlock": {
    "ApplicationName": "Materal.Wechat",
    "LoadFromRootPath": true,
    "LoadFromPlugins": true,
    "Plugins": []
  },
  "Swagger": {
    "Enable": true,
    "Title": "Wechat应用程序",
    "Version": "v1",
    "Description": "提供WebAPI接口",
    "EnableAuthentication": null
  },
  "Web": {
    "BaseUrl": "http://127.0.0.1:10000",
    "HttpBodyMaxSize": 104857600,
    "UsePascalCase": true
  },
  "Wechat": {
    "WechatOptions": [
      {
        "Key": "Default",
        "AppID": "wx70304783c61523fd",
        "AppSecret": "87446a5f313f75fdb3e9bbfa0d894fe1",
        "MchId": "1738627876",
        "ApiV3Key": "FDDC7BE1582D4A499E35930C6082C826",
        "CertificateSerialNumber": "4B6EBA0804DE3E0E238FE713E16B9CB3B109EAA3",
        "PrivateKeyPath": "apiclient_key.pem",
        "NotifyUrl": "https://gateway.gameyhs.com/WechatAPI/WechatAPI/WechatPay/PayNotify",
        "PlatformPublicKeyId": "PUB_KEY_ID_0117386278762026030800211952000400",
        "PlatformPublicKeyPath": "pub_key.pem"
      }
    ]
  }
}